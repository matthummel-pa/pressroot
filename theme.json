{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": { "contentSize": "760px", "wideSize": "1180px" },
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "defaultDuotone": false,
      "custom": true,
      "customGradient": true,
      "customDuotone": true,
      "link": true,
      "heading": true,
      "button": true,
      "caption": true,
      "background": true,
      "text": true,
      "palette": [
        { "slug": "paper", "color": "#FFFDF7", "name": "Paper" },
        { "slug": "surface", "color": "#FFFFFF", "name": "Surface" },
        { "slug": "cream", "color": "#F6F1FF", "name": "Cream" },
        { "slug": "ink", "color": "#1B1830", "name": "Ink" },
        { "slug": "body", "color": "#4A4660", "name": "Body" },
        { "slug": "muted", "color": "#5A5676", "name": "Muted" },
        { "slug": "faint", "color": "#7C75A8", "name": "Faint" },
        { "slug": "green", "color": "#7C5CFF", "name": "Brand (Purple)" },
        { "slug": "green-ink", "color": "#6A4AE0", "name": "Brand hover" },
        { "slug": "green-tint", "color": "#EFE9FF", "name": "Brand tint" },
        { "slug": "purple", "color": "#7C5CFF", "name": "Purple" },
        { "slug": "orange", "color": "#FF7A1A", "name": "Orange" },
        { "slug": "lime", "color": "#C2F23D", "name": "Lime" },
        { "slug": "sky", "color": "#38BDF8", "name": "Sky" },
        { "slug": "pink", "color": "#FF5DA2", "name": "Pink" },
        { "slug": "line", "color": "#ECE4F8", "name": "Line" }
      ],
      "gradients": [
        { "slug": "green", "name": "Brand", "gradient": "linear-gradient(135deg,#7C5CFF,#38BDF8)" },
        { "slug": "purple-sky", "name": "Purple to Sky", "gradient": "linear-gradient(135deg,#7C5CFF,#38BDF8)" },
        { "slug": "orange-pink", "name": "Orange to Pink", "gradient": "linear-gradient(135deg,#FF7A1A,#FF5DA2)" },
        { "slug": "headline", "name": "Headline Accent", "gradient": "linear-gradient(100deg,#FF7A1A,#7C5CFF,#38BDF8)" },
        { "slug": "ink", "name": "Ink", "gradient": "linear-gradient(135deg,#1B1830,#2b2f36)" },
        { "slug": "paper-fade", "name": "Paper fade", "gradient": "linear-gradient(180deg,#FFFDF7,#F6F1FF)" }
      ],
      "duotone": [
        { "slug": "green-ink", "name": "Purple / Ink", "colors": ["#1B1830", "#7C5CFF"] },
        { "slug": "paper-green", "name": "Purple / Paper", "colors": ["#7C5CFF", "#FFFDF7"] }
      ]
    },
    "typography": {
      "fluid": true,
      "customFontSize": true,
      "lineHeight": true,
      "letterSpacing": true,
      "textTransform": true,
      "textDecoration": true,
      "fontStyle": true,
      "fontWeight": true,
      "dropCap": true,
      "writingMode": false,
      "fontFamilies": [
        {
          "slug": "display",
          "name": "Outfit",
          "fontFamily": "Outfit, ui-sans-serif, system-ui, sans-serif",
          "fontFace": [
            { "fontFamily": "Outfit", "fontWeight": "400 900", "fontStyle": "normal", "fontStretch": "normal", "src": ["file:./resources/fonts/Outfit-Variable.woff2"] }
          ]
        },
        {
          "slug": "body",
          "name": "Outfit (Body)",
          "fontFamily": "Outfit, ui-sans-serif, system-ui, sans-serif"
        },
        {
          "slug": "serif",
          "name": "Instrument Serif",
          "fontFamily": "\"Instrument Serif\", Georgia, serif",
          "fontFace": [
            { "fontFamily": "Instrument Serif", "fontWeight": "400", "fontStyle": "normal", "src": ["file:./resources/fonts/InstrumentSerif-Regular.woff2"] },
            { "fontFamily": "Instrument Serif", "fontWeight": "400", "fontStyle": "italic", "src": ["file:./resources/fonts/InstrumentSerif-Italic.woff2"] }
          ]
        },
        {
          "slug": "mono",
          "name": "JetBrains Mono",
          "fontFamily": "\"JetBrains Mono\", ui-monospace, SFMono-Regular, Menlo, Consolas, monospace",
          "fontFace": [
            { "fontFamily": "JetBrains Mono", "fontWeight": "400 600", "fontStyle": "normal", "src": ["file:./resources/fonts/JetBrainsMono-Variable.woff2"] }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "15px", "name": "Small" },
        { "slug": "medium", "size": "17px", "name": "Medium" },
        { "slug": "large", "size": "22px", "name": "Large" },
        { "slug": "x-large", "size": "clamp(28px, 3vw, 34px)", "name": "X-Large" },
        { "slug": "huge", "size": "clamp(48px, 7vw, 88px)", "name": "Huge" }
      ]
    },
    "spacing": {
      "units": ["px", "em", "rem", "%", "vw", "vh"],
      "padding": true,
      "margin": true,
      "blockGap": true,
      "customSpacingSize": true,
      "spacingSizes": [
        { "slug": "20", "size": "0.5rem", "name": "XS" },
        { "slug": "30", "size": "1rem", "name": "S" },
        { "slug": "40", "size": "1.5rem", "name": "M" },
        { "slug": "50", "size": "2.5rem", "name": "L" },
        { "slug": "60", "size": "4rem", "name": "XL" },
        { "slug": "70", "size": "6rem", "name": "XXL" }
      ]
    },
    "border": { "color": true, "radius": true, "style": true, "width": true },
    "shadow": {
      "defaultPresets": false,
      "presets": [
        { "slug": "soft", "name": "Soft", "shadow": "0 6px 20px rgba(23,25,30,.08)" },
        { "slug": "lift", "name": "Lift", "shadow": "0 12px 30px rgba(23,25,30,.12)" },
        { "slug": "ring", "name": "Ring", "shadow": "0 0 0 1px #e6e2d9" }
      ]
    },
    "dimensions": { "minHeight": true, "aspectRatio": true },
    "position": { "sticky": true },
    "background": { "backgroundImage": true, "backgroundSize": true }
  }
}
