{
  "name": "sage",
  "private": true,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint:js": "eslint resources/js",
    "lint:php": "vendor/bin/pint --test app",
    "lint": "npm run lint:js && npm run lint:php",
    "refresh": "npm run lint && npm run build",
    "wp": "wp-playground-cli server --php=8.3 --port=8881 --workers=6 --login --blueprint=.playground/blueprint.json --mount=.:/wordpress/wp-content/themes/pressroot --mount-before-install=.playground/database:/wordpress/wp-content/database --mount=.playground/uploads:/wordpress/wp-content/uploads --mount=.playground/mu-plugins:/wordpress/wp-content/mu-plugins",
    "build": "vite build",
    "translate": "npm run translate:pot && npm run translate:update",
    "translate:pot": "wp i18n make-pot . ./resources/lang/pressroot.pot --include=\"theme.json,patterns,app,resources\"",
    "translate:update": "for file in ./resources/lang/*.po; do wp i18n update-po ./resources/lang/pressroot.pot $file; done",
    "translate:compile": "npm run translate:mo && npm run translate:js",
    "translate:js": "wp i18n make-json ./resources/lang --pretty-print",
    "translate:mo": "wp i18n make-mo ./resources/lang ./resources/lang"
  },
  "devDependencies": {
    "@roots/vite-plugin": "^2.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@wp-playground/cli": "^3.1.43",
    "eslint": "^9.15.0",
    "laravel-vite-plugin": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^8.0.0"
  }
}